{
  "manifest_version": 3,
  "name": "VIGIL",
  "version": "1.0.0",
  "description": "Privacy-first browser attention analytics",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Analyzer"
  }
}
